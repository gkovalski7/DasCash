# DasCash API — desarrollo local (copiar a .env)
DJANGO_SECRET_KEY=insecure-secret
DJANGO_DEBUG=1
POSTGRES_DB=cashback
POSTGRES_USER=cashback
POSTGRES_PASSWORD=2044
POSTGRES_HOST=db
POSTGRES_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOAD_SEEDS=true

# Recuperación de contraseña (dev: imprime el email en consola)
FRONTEND_URL=http://localhost:5173
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Mercado Pago (flujo QR)
# Credenciales de prueba: panel MP → Tus integraciones → Credenciales de prueba
MP_ACCESS_TOKEN=
# Clave secreta del webhook (panel MP → Webhooks → Clave secreta).
# En DEBUG puede quedar vacío (el webhook no valida firma); en producción es obligatorio.
MP_WEBHOOK_SECRET=
MP_SANDBOX=true
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
