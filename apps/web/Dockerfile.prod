# Frontend producción: build de Vite servido por nginx
# (la config de nginx se monta desde infra/nginx/dascash.conf vía compose)
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci || npm install
COPY . .
# Vacío = API same-origin detrás del proxy nginx
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
