# DasCash — variables de producción
# Copiar a infra/.env.prod, completar y NUNCA commitear el .env.prod real.
#   docker compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod up --build -d

# ── Obligatorias (el compose falla si faltan) ─────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
POSTGRES_USER=dascash
POSTGRES_PASSWORD=
POSTGRES_DB=dascash
# Credenciales de producción de Mercado Pago (APP_USR-...)
MP_ACCESS_TOKEN=
# Clave secreta del webhook: panel MP → Tus integraciones → Webhooks → Clave secreta
MP_WEBHOOK_SECRET=

# ── Dominio ───────────────────────────────────────────────────────────
ALLOWED_HOSTS=dascash.com.ar,www.dascash.com.ar
CORS_ALLOWED_ORIGINS=https://dascash.com.ar,https://www.dascash.com.ar
FRONTEND_URL=https://dascash.com.ar
BACKEND_BASE_URL=https://dascash.com.ar
FRONTEND_BASE_URL=https://dascash.com.ar

# ── Mercado Pago ──────────────────────────────────────────────────────
# false = pagos reales; true = sandbox (para la demo se puede dejar true)
MP_SANDBOX=false

# ── Email (SMTP real para recuperación de contraseña) ────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=DasCash <noreply@dascash.com.ar>

# ── HTTPS (activar cuando el dominio ya tenga TLS) ───────────────────
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
